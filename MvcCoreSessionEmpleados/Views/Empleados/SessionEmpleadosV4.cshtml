@model List<Empleado>

<h1 style="color:yellow">
    Empleados Session V4
</h1>

<p>
    <a asp-controller="Empleados" asp-action="EmpleadosAlmacenadosV4">
        Empleados almacenados V4
    </a>
</p>

<h3 style="color:green">
    @ViewData["MENSAJE"]
</h3>

@if(Model != null)
{
    <ul class="list-group">
        @foreach (Empleado empleado in Model)
        {
            <li class="list-group-item list-group-item-danger">
                @empleado.Apellido
                <a asp-controller="Empleados" asp-action="SessionEmpleadosV4"
                   asp-route-idempleado="@empleado.IdEmpleado">
                    Almacenar empleado
                </a>
            </li>
        }
    </ul>
}

